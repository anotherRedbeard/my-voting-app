@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center">
    <h1 class="display-4">Vote for Your Favorite</h1>
    <p class="lead">Choose an item below and cast your vote!</p>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger text-center" role="alert">
        @Model.ErrorMessage
    </div>
}

@if (Model.ShowResults)
{
    <div class="alert alert-success text-center" role="alert">
        Your vote has been recorded! Here are the current totals:
    </div>

    <div class="row justify-content-center">
        @foreach (var result in Model.Results)
        {
            <div class="col-12 col-sm-6 col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@result.Item.Name</h5>
                        @if (!string.IsNullOrWhiteSpace(result.Item.Description))
                        {
                            <p class="card-text text-muted">@result.Item.Description</p>
                        }
                        <p class="mt-auto mb-0 fs-4 text-primary fw-bold">
                            @result.VoteCount vote@(result.VoteCount != 1 ? "s" : "")
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="text-center mt-3">
        <a asp-page="/Index" class="btn btn-outline-primary">Vote Again</a>
    </div>
}
else if (Model.Items.Count == 0)
{
    <div class="alert alert-info text-center" role="alert">
        No items available for voting at this time.
    </div>
}
else
{
    <div class="row justify-content-center">
        @foreach (var item in Model.Items)
        {
            <div class="col-12 col-sm-6 col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.Name</h5>
                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <p class="card-text text-muted">@item.Description</p>
                        }
                        <form method="post" class="mt-auto">
                            <input type="hidden" name="itemId" value="@item.Id" />
                            <button type="submit" class="btn btn-primary w-100">
                                Vote
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

